{
  "private": true,
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "doc": "pnpm run -C ./docs docs:dev",
    "test": "vitest --ui",
    "coverage": "vitest run --coverage",
    "lint:es": "eslint",
    "lint:fix": "eslint --fix",
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm run -C ./scripts build",
    "prepare": "husky",
    "clean": "pnpm exec rimraf dist"
  },
  "dependencies": {
    "lodash-es": "^4.17.21",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.3",
    "@eslint/js": "^9.22.0",
    "@stylistic/eslint-plugin": "^4.2.0",
    "@testing-library/vue": "^8.1.0",
    "@types/jsdom": "^21.1.7",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/browser": "^3.0.6",
    "@vitest/coverage-v8": "^3.0.9",
    "@vitest/ui": "^3.0.6",
    "@vue/test-utils": "^2.4.6",
    "@wdt/components": "workspace:^",
    "@wdt/defines": "workspace:^",
    "@wdt/hooks": "workspace:^",
    "@wdt/styles": "workspace:^",
    "@wdt/utils": "workspace:^",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.0",
    "playwright": "^1.50.1",
    "postcss": "^8.5.1",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "resize-observer-polyfill": "^1.5.1",
    "rimraf": "^6.0.1",
    "sass": "^1.83.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.1.1",
    "vitest": "^3.0.6",
    "vitest-browser-vue": "^0.2.0"
  },
  "lint-staged": {
    "packages/**/*.{ts,vue}": "npm run lint:es",
    "scripts/**/*.ts": "npm run lint:es"
  },
  "engines": {
    "node": ">=20.13.1",
    "pnpm": ">=9"
  }
}
